# AeroPlace - Environment Variables Template
#
# 이 파일은 애플리케이션 빌드 및 배포 환경에서 필요한 API 키들을 로드하기 위한 예시 파일입니다.
# 실제 키를 적용하시려면 이 파일을 복사하여 `.env` 또는 `.env.local` 파일을 생성한 뒤,
# 아래의 변수 값들을 기입해 주십시오.

# 1. OpenWeatherMap API Key (실시간 기상 데이터용)
# 발급처: https://openweathermap.org/api
REACT_APP_WEATHER_KEY=your_openweathermap_api_key_here

# 2. Kakao Local API Rest Key (도시/주소 검색 및 위도·경도 치환용)
# 발급처: https://developers.kakao.com (내 애플리케이션 -> 앱 키 -> REST API 키)
REACT_APP_KAKAO_KEY=your_kakao_rest_api_key_here
